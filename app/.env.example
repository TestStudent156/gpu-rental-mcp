# Band agent credentials come from agent_config.yaml (see agent_config.yaml.example),
# NOT from env. The SDK's REST/WS URLs default to app.band.ai. The only env var the
# app actually needs is the Anthropic key for the agents' LLM calls.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional (only if overriding the Band defaults):
# BAND_REST_URL=https://app.band.ai
